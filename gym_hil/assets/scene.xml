<mujoco model="Scene">
  <include file="panda.xml"/>

  <option timestep=".002" noslip_iterations="5" noslip_tolerance="0"/>

  <statistic center="0.3 0 0.4" extent=".8"/>

  <visual>
    <headlight diffuse=".4 .4 .4" ambient=".5 .5 .5"/>
    <global azimuth="160" elevation="-20" offheight="128" offwidth="128"/>
    <quality offsamples="8"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1=".3 .5 .7" rgb2="0 0 0" width="32" height="512"/>
    <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".1 .2 .3" rgb2=".2 .3 .4"/>
    <material name="grid" texture="grid" texrepeat="2 2" texuniform="true" reflectance="0"/>
  </asset>

  <worldbody>
    <camera name="front" pos="1.3 0.0 0.7" quat="0.5963678 0.3799282 0.3799282 0.5963678" fovy="45"/>
    <light pos="0 0 3" dir="0 0 -1" diffuse="1 1 1" specular=".3 .3 .3"/>
    <light pos="0 -.5 .4" mode="targetbodycom" target="usb_plug" diffuse=".8 .8 .8" specular=".3 .3 .3"/>
    <geom name="floor" size="3 3 0.01" type="plane" material="grid"/>

    <!-- USB 插头（可抓取，竖直） -->
    <!-- 兼容旧任务：freejoint / geom 仍使用 block 名 -->
    <body name="usb_plug" pos="0.50 0.00 0.060">
      <freejoint name="block"/>
      <geom name="block"
            type="box"
            size="0.010 0.006 0.025"
            mass="0.15"
            friction="0.90 0.05 0.01"
            rgba="0.18 0.35 0.95 1"/>

      <!-- 顶部金属头（仅视觉） -->
      <geom name="usb_tip_visual"
            type="box"
            pos="0 0 0.030"
            size="0.008 0.004 0.005"
            contype="0" conaffinity="0"
            rgba="0.82 0.82 0.86 1"/>
    </body>

      <!-- 插座（固定，四周包围，顶部开口向下插） -->
      <!-- 标准插拔：端子-插座每侧间隙 0.1mm -->
      <!-- 修正1: x=0.56（更可达） -->
      <!-- 修正2: z=0.000（贴地） -->
    <body name="usb_socket" pos="0.56 0.00 0.000">
      <!-- 底板 -->
<geom name="socket_bottom"
      type="box"
      pos="0 0 0.0035"
      size="0.0209 0.0159 0.0035"
      mass="0.30"
      friction="1.00 0.05 0.01"
      rgba="0.42 0.42 0.45 1"/>

<geom name="socket_wall_front"
      type="box"
      pos="0.0126 0 0.0285"
      size="0.0025 0.0159 0.0215"
      mass="0.05"
      friction="1.00 0.05 0.01"
      rgba="0.62 0.62 0.65 1"/>

<geom name="socket_wall_back"
      type="box"
      pos="-0.0126 0 0.0285"
      size="0.0025 0.0159 0.0215"
      mass="0.05"
      friction="1.00 0.05 0.01"
      rgba="0.62 0.62 0.65 1"/>

<geom name="socket_wall_left"
      type="box"
      pos="0 0.0091 0.0285"
      size="0.01145 0.0030 0.0215"
      mass="0.05"
      friction="1.00 0.05 0.01"
      rgba="0.66 0.66 0.69 1"/>

<geom name="socket_wall_right"
      type="box"
      pos="0 -0.0091 0.0285"
      size="0.01145 0.0030 0.0215"
      mass="0.05"
      friction="1.00 0.05 0.01"
      rgba="0.66 0.66 0.69 1"/>

<geom name="socket_rim_visual"
      type="box"
      pos="0 0 0.0505"
      size="0.0126 0.0091 0.0010"
      contype="0" conaffinity="0"
      rgba="0.15 0.15 0.15 0.35"/>

      <!-- 插座开口中心点（用于插入判定） -->
      <site name="socket_entry_site"
            pos="0 0 0.050"
            size="0.002"
            rgba="1 0 0 0.6"/>
    </body>

    <!-- 保持与原任务兼容的 mocap target -->
    <body name="target" pos=".15 0 .5" quat="0 1 0 0" mocap="true">
      <geom name="target" type="box" size=".03 .03 .03" contype="0" conaffinity="0" rgba=".6 .3 .3 0"/>
    </body>
  </worldbody>

  <sensor>
    <!-- 保持旧任务命名 -->
    <framepos name="block_pos" objtype="geom" objname="block"/>
    <framequat name="block_quat" objtype="geom" objname="block"/>

    <!-- 新增插座入口位置传感器 -->
    <framepos name="socket_entry_pos" objtype="site" objname="socket_entry_site"/>
  </sensor>
</mujoco>
